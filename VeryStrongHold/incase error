repeat task.wait() until game:IsLoaded()

if game.PlaceId == 96516249626799 or game.PlaceId == 8811271345 then

    local Player = game.Players.LocalPlayer
    local Character = Player.Character or Player.CharacterAdded:Wait()
    local Backpack = Player:WaitForChild("Backpack")
    
    local targetWeapon = "Equinox Slicer"
    local artifactName = "Mysterious Artifact"
    local safeZone = Vector3.new(-950000.23584, 950000.05774, -1651.85693)

    --// 1. IMMEDIATE WEAPON & SAFETY TELEPORT CHECK
    print("Checking item requirements...")
    local hasWeapon = Character:FindFirstChild(targetWeapon) or Backpack:FindFirstChild(targetWeapon)
    
    if not hasWeapon then
        print("Required weapon not found! Resetting...")
        if Character:FindFirstChildOfClass("Humanoid") then
            Character:FindFirstChildOfClass("Humanoid").Health = 0
        end
        return -- Stop script execution
    end

    print("Weapon verified! Performing instant safe-zone setup...")
    
    -- Teleport to safety right away
    if Character:FindFirstChild("HumanoidRootPart") then
        Character:MoveTo(safeZone)
    end
    task.wait(0.1)

    -- Build the safe grid platform immediately
    local rightLeg = Character:WaitForChild("Right Leg", 5)
    local rootPart = Character:WaitForChild("HumanoidRootPart", 5)

    if rightLeg and rootPart then
        local NewPart = Instance.new("Part")
        NewPart.Parent = workspace
        NewPart.Size = Vector3.new(1000, 1000.1, 1000)
        NewPart.BrickColor = BrickColor.new("Blue")
        NewPart.Anchored = true
        NewPart.CFrame = rightLeg.CFrame
        task.wait(0.5)
    end

    --// 2. SPAWN CONFIRMATION PART FOR OTHER SCRIPTS (Stays permanently)
    local VerifyPart = Instance.new("Part")
    VerifyPart.Parent = workspace
    VerifyPart.Size = Vector3.new(1, 1, 1)
    VerifyPart.BrickColor = BrickColor.new("Blue")
    VerifyPart.Name = "Verify Done!"
    VerifyPart.Anchored = true
    VerifyPart.CanCollide = false
    VerifyPart.Transparency = 1 
    task.wait(0.5)

    --// 3. PLACE-SPECIFIC TELEPORT PIPELINE
    if game.PlaceId == 8811271345 then
        print("Target PlaceId recognized! Proceeding straight to matchmaking systems...")

        -- Auto-Equip Key Teleport Item
        repeat
            task.wait(0.5)
            local artifact = Backpack:FindFirstChild(artifactName)
            if artifact then
                artifact.Parent = Character
            end
        until Character:FindFirstChild(artifactName)

        -- Matchmaking Remote Pipeline Execution
        task.wait(1.5)
        local activeArtifact = Character:WaitForChild(artifactName, 5)
        if activeArtifact and activeArtifact:FindFirstChild("WeaponRemote") then
            local useArgs = { "use", {} }
            pcall(function()
                activeArtifact.WeaponRemote:FireServer(unpack(useArgs))
            end)
        end

        task.wait(0.5)
        local partySystemArgs = {
            "createParty",
            {
                settings = {
                    FriendsOnly = true,
                    Visual = true
                },
                subplace = "Stronghold"
            }
        }
        pcall(function()
            game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("PartySystem"):WaitForChild("PartyFunction"):InvokeServer(unpack(partySystemArgs))
        end)

        task.wait(0.5)
        local joinArgs = { "joinSubplace", {} }
        pcall(function()
            game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("PartySystem"):WaitForChild("PartyFunction"):InvokeServer(unpack(joinArgs))
        end)
        
        print("--RELOAD!--")
    else
        print("Different PlaceId detected. Safety platform generated, skipped teleport execution.")
    end
    
    -- Clean up block removed. "Verify Done!" stays active in workspace.
end
