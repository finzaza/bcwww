local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local hrp = character:WaitForChild("HumanoidRootPart")

-- CONFIGURATION
local SETTINGS = {
    Range = 150,
}

-- Add your egg names here. Set to true to collect, false to ignore.
local ALLOWED_EGGS = {
    ["EggBadlands"] = false,
    ["noobegg"]  = false,
    ["CommonEgg"]   = true,
    -- You can add as many as you want following this format
}

local function bringPart(part)
    part.Anchored = false
    part.CanCollide = false
    
    -- Continuously forces the egg to your position 60 times a second to fight server lag
    local connection
    connection = RunService.RenderStepped:Connect(function()
        if part and part.Parent and character and hrp then
            part.CFrame = hrp.CFrame * CFrame.new(0, 2, -2)
            part.Velocity = Vector3.new(0, 0, 0)
        else
            if connection then connection:Disconnect() end
        end
    end)
    
    -- Stop tracking after 2 seconds (giving it enough time to register the touch)
    task.delay(2, function()
        if connection then connection:Disconnect() end
    end)
end

local function scanForEggs()
    for _, item in ipairs(workspace:GetDescendants()) do
        -- 1. Check if it's a MeshPart with a TouchInterest
        if item:IsA("MeshPart") and item:FindFirstChild("TouchInterest") then
            
            -- 2. Check if this specific egg name is enabled in our config
            if ALLOWED_EGGS[item.Name] == true then
                local distance = (item.Position - hrp.Position).Magnitude
                
                -- 3. Check if it's within range
                if distance <= SETTINGS.Range then
                    print("Bringing targeted egg: " .. item.Name)
                    bringPart(item)
                end
            end
            
        end
    end
end

-- Scan every 1 second
while true do
    scanForEggs()
    task.wait(1)
end
