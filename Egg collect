local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local hrp = character:WaitForChild("HumanoidRootPart")

-- CONFIGURATION
local SETTINGS = {
    Range = 150,
}

-- Type your egg names here in ALL LOWERCASE letters.
local ALLOWED_EGGS = {
    ["eggbadlands"] = true,
    ["eggvolcano"]  = false,
    ["commonegg"]   = true,
}

local function bringPart(part)
    part.Anchored = false
    part.CanCollide = false
    
    local connection
    connection = RunService.RenderStepped:Connect(function()
        if part and part.Parent and character and hrp then
            part.CFrame = hrp.CFrame * CFrame.new(0, 2, -2)
            part.Velocity = Vector3.new(0, 0, 0)
        else
            if connection then connection:Disconnect() end
        end
    end)
    
    task.delay(2, function()
        if connection then connection:Disconnect() end
    end)
end

local function scanForEggs()
    for _, item in ipairs(workspace:GetDescendants()) do
        if item:IsA("MeshPart") and item:FindFirstChild("TouchInterest") then
            
            -- Get the lowercase names of the part AND its parent model
            local partNameLower = string.lower(item.Name)
            local parentNameLower = item.Parent and string.lower(item.Parent.Name) or ""
            
            -- Check if either name matches our allowed list
            if ALLOWED_EGGS[partNameLower] == true or ALLOWED_EGGS[parentNameLower] == true then
                local distance = (item.Position - hrp.Position).Magnitude
                
                if distance <= SETTINGS.Range then
                    print("Bringing targeted egg: " .. item.Name)
                    bringPart(item)
                end
            end
            
        end
    end
end

while true do
    scanForEggs()
    task.wait(1)
end
