local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local hrp = character:WaitForChild("HumanoidRootPart")

-- CONFIGURATION
local SETTINGS = {
    Range = 150,
}

-- You can add more egg here and change it true
local ALLOWED_EGGS = {
    ["EggNormal"] = true, -- Try changing this based on console output
}

local function bringPart(part)
    part.Anchored = false
    part.CanCollide = false
    
    local connection
    connection = RunService.RenderStepped:Connect(function()
        if part and part.Parent and character and hrp then
            part.CFrame = hrp.CFrame * CFrame.new(0, 2, -2)
            part.Velocity = Vector3.new(0, 0, 0)
        else
            if connection then connection:Disconnect() end
        end
    end)
    
    task.delay(2, function()
        if connection then connection:Disconnect() end
    end)
end

local function scanForEggs()
    for _, item in ipairs(workspace:GetDescendants()) do
        if item:IsA("MeshPart") and item:FindFirstChild("TouchInterest") then
            local distance = (item.Position - hrp.Position).Magnitude
            
            if distance <= SETTINGS.Range then
                -- THIS WILL PRINT THE EXACT NAMES TO YOUR F9 CONSOLE
                print("--- EGG DETECTED ---")
                print("MeshPart Name: '" .. item.Name .. "'")
                print("Parent Model Name: '" .. (item.Parent and item.Parent.Name or "None") .. "'")
                print("--------------------")
                
                -- Check if either name exactly matches our allowed list
                if ALLOWED_EGGS[item.Name] == true or (item.Parent and ALLOWED_EGGS[item.Parent.Name] == true) then
                    bringPart(item)
                end
            end
        end
    end
end

while true do
    scanForEggs()
    task.wait(1)
end
